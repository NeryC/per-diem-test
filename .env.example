# Per Diem Square Menu Browser — local environment
# Copy this file to .env.local and fill in real values. .env.local is git-ignored.
# Never commit real credentials.

# Square Access Token
# Obtain from: https://developer.squareup.com → your application → Sandbox → Credentials
# Sandbox tokens look like: EAAAl... (~64 chars). Server-only — never exposed to the client.
SQUARE_ACCESS_TOKEN=

# Which Square environment to talk to.
# Allowed values: "sandbox" | "production". Default is sandbox if unset.
# Production should ONLY be used after explicit owner approval; this take-home stays on sandbox.
SQUARE_ENVIRONMENT=sandbox
